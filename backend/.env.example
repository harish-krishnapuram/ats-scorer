# App
ENV=development
DEBUG=True

# Security
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# SQLite (default, for quick local dev)
DATABASE_URL=sqlite:///./ats.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/ats_db
# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/ats_db

# CORS (comma-separated in real .env parsing depends on pydantic-settings list support)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File uploads
UPLOAD_DIR=app/uploads/resumes
MAX_UPLOAD_SIZE_MB=10
